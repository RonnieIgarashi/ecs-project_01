# Python / Django
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv*/
venv/
*.egg-info/
staticfiles/
.env

# Terraform ローカルディレクトリ
.terraform/

# tfstate ファイル（インフラの現状を記録する状態ファイル。ローカル管理）
*.tfstate
*.tfstate.*

# クラッシュログ
crash.log
crash.*.log

# .tfvars ファイル（パスワード・シークレット等の機密情報を含む可能性があるため除外）
*.tfvars
*.tfvars.json

# overrideファイル（ローカル環境での一時的な上書き設定のため除外）
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# terraform apply 実行時に生成されるロックファイル
.terraform.tfstate.lock.info

# terraform plan -out=tfplan で生成されるプランファイル
# 例: *tfplan*

# Terraform CLI設定ファイル
.terraformrc
terraform.rc
