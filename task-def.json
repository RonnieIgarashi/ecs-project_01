{
    "family": "ecs-project-01-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::335142514101:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "flask",
            "image": "335142514101.dkr.ecr.ap-northeast-1.amazonaws.com/ecs-project-01:latest",
            "portMappings": [
                {
                "containerPort": 5000,
                "protocol": "tcp"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/ecs-project-01",
                    "awslogs-region": "ap-northeast-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ]
}
